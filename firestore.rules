rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasUserProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/user/$(request.auth.uid));
    }

    function currentUserProfile() {
      return get(/databases/$(database)/documents/user/$(request.auth.uid)).data;
    }

    function isActiveUser() {
      return signedIn()
        && currentUserProfile().status in ['active', 'Active', 'ACTIVE'];
    }

    function isActiveStaff() {
      return isActiveUser()
        && currentUserProfile().role in [
          'admin',
          'director',
          'Admin',
          'Director',
          'ADMIN',
          'DIRECTOR',
        ];
    }

    function canChangeStudentCourse() {
      return isActiveUser()
        && currentUserProfile().role in [
          'admin',
          'director',
          'Admin',
          'Director',
          'ADMIN',
          'DIRECTOR',
        ];
    }

    function canManageAttendance() {
      return isActiveUser()
        && currentUserProfile().role in [
          'admin',
          'director',
          'docente',
          'Admin',
          'Director',
          'Docente',
          'ADMIN',
          'DIRECTOR',
          'DOCENTE',
        ];
    }

    function validTeacher() {
      return request.resource.data.keys().hasAll([
          'email',
          'authUid',
          'firstName',
          'lastName',
          'birthDate',
          'nationality',
          'gender',
          'idNumber',
          'address',
          'phone',
          'assignments',
          'courses',
          'photoUrl',
          'photoPath',
          'status',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.keys().hasOnly([
          'email',
          'authUid',
          'firstName',
          'lastName',
          'birthDate',
          'nationality',
          'gender',
          'idNumber',
          'address',
          'phone',
          'assignments',
          'courses',
          'photoUrl',
          'photoPath',
          'status',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.authUid is string
        && request.resource.data.authUid.size() > 0
        && request.resource.data.firstName is string
        && request.resource.data.firstName.size() > 0
        && request.resource.data.lastName is string
        && request.resource.data.lastName.size() > 0
        && request.resource.data.idNumber is string
        && request.resource.data.assignments is list
        && request.resource.data.courses is list
        && request.resource.data.status == 'active'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function validTeacherUserProfile() {
      return request.resource.data.keys().hasAll([
          'email',
          'fullName',
          'role',
          'codigo',
          'institucion',
          'distrito',
          'status',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.keys().hasOnly([
          'email',
          'fullName',
          'role',
          'codigo',
          'institucion',
          'distrito',
          'status',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() > 0
        && request.resource.data.role == 'docente'
        && request.resource.data.codigo is string
        && request.resource.data.codigo.size() > 0
        && request.resource.data.institucion is string
        && request.resource.data.institucion.size() > 0
        && request.resource.data.distrito is string
        && request.resource.data.distrito.size() > 0
        && request.resource.data.status == 'active'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function validAttendance() {
      return request.resource.data.keys().hasAll([
          'course',
          'subject',
          'date',
          'records',
          'createdBy',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.keys().hasOnly([
          'course',
          'subject',
          'date',
          'records',
          'createdBy',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.course is string
        && request.resource.data.course.size() > 0
        && request.resource.data.subject is string
        && request.resource.data.subject.size() > 0
        && request.resource.data.date is string
        && request.resource.data.date.size() == 10
        && request.resource.data.records is list
        && request.resource.data.records.size() > 0
        && request.resource.data.createdBy is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function validStudent() {
      return request.resource.data.keys().hasAll([
          'nombres',
          'apellidos',
          'fechaNacimiento',
          'nacionalidad',
          'genero',
          'curso',
          'asignaturas',
          'nombreMadre',
          'cedulaMadre',
          'nombrePadre',
          'cedulaPadre',
          'direccion',
          'telefonoContacto',
          'fotoUrl',
          'estado',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.keys().hasOnly([
          'nombres',
          'apellidos',
          'fechaNacimiento',
          'nacionalidad',
          'genero',
          'curso',
          'asignaturas',
          'nombreMadre',
          'cedulaMadre',
          'nombrePadre',
          'cedulaPadre',
          'direccion',
          'telefonoContacto',
          'fotoUrl',
          'estado',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.nombres is string
        && request.resource.data.nombres.size() > 0
        && request.resource.data.apellidos is string
        && request.resource.data.apellidos.size() > 0
        && request.resource.data.fechaNacimiento is string
        && request.resource.data.fechaNacimiento.size() == 10
        && request.resource.data.nacionalidad is string
        && request.resource.data.genero is string
        && request.resource.data.curso is string
        && request.resource.data.curso.size() > 0
        && request.resource.data.asignaturas is list
        && request.resource.data.asignaturas.size() > 0
        && request.resource.data.nombreMadre is string
        && request.resource.data.cedulaMadre is string
        && request.resource.data.nombrePadre is string
        && request.resource.data.cedulaPadre is string
        && request.resource.data.direccion is string
        && request.resource.data.telefonoContacto is string
        && request.resource.data.fotoUrl is string
        && request.resource.data.estado in ['activo', 'active']
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function studentCourseUnchanged() {
      return request.resource.data.curso == resource.data.curso;
    }

    function validStudentCourseUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'curso',
          'asignaturas',
          'updatedAt',
        ])
        && request.resource.data.curso is string
        && request.resource.data.curso.size() > 0
        && request.resource.data.asignaturas is list
        && request.resource.data.asignaturas.size() > 0
        && request.resource.data.updatedAt is timestamp;
    }


    function validBreakdown() {
      return request.resource.data.keys().hasAll([
          'category',
          'description',
          'priority',
          'location',
          'photoUrl',
          'photoDataUrl',
          'photoName',
          'photoContentType',
          'status',
          'notes',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.keys().hasOnly([
          'category',
          'description',
          'priority',
          'location',
          'photoUrl',
          'photoDataUrl',
          'photoName',
          'photoContentType',
          'status',
          'notes',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.category is string
        && request.resource.data.category.size() > 0
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.priority in ['low', 'medium', 'high']
        && request.resource.data.location is string
        && request.resource.data.location.size() > 0
        && (request.resource.data.photoUrl == null || request.resource.data.photoUrl is string)
        && (request.resource.data.photoDataUrl == null || request.resource.data.photoDataUrl is string)
        && (request.resource.data.photoName == null || request.resource.data.photoName is string)
        && (request.resource.data.photoContentType == null || request.resource.data.photoContentType in ['image/jpeg'])
        && request.resource.data.status in ['pending', 'in-progress', 'resolved']
        && (request.resource.data.notes == null || request.resource.data.notes is string)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    match /user/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if isActiveStaff() && validTeacherUserProfile();
      allow update, delete: if false;
    }

    match /estudiantes/{studentId} {
      allow create: if isActiveStaff() && validStudent();
      allow update: if (canChangeStudentCourse() && validStudentCourseUpdate())
        || (isActiveStaff() && studentCourseUnchanged() && validStudent());
      allow delete: if isActiveStaff();
      allow read: if canManageAttendance();
    }

    match /docentes/{teacherId} {
      allow create: if isActiveStaff() && validTeacher();
      allow update: if isActiveStaff() && validTeacher();
      allow read, delete: if isActiveStaff();
    }

    match /asistencias/{attendanceId} {
      allow read: if canManageAttendance();
      allow create, update: if validAttendance()
        && (
          canManageAttendance()
          || (hasUserProfile() && request.resource.data.createdBy == request.auth.uid)
        );
      allow delete: if isActiveStaff();
    }

    match /breakdowns/{breakdownId} {
      allow read: if canManageAttendance();
      allow create, update: if canManageAttendance() && validBreakdown();
      allow delete: if isActiveStaff();
    }
  }
}
