rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserProfile() {
      return get(/databases/$(database)/documents/user/$(request.auth.uid)).data;
    }

    function isActiveStaff() {
      return signedIn()
        && currentUserProfile().status in ['active', 'Active', 'ACTIVE']
        && currentUserProfile().role in [
          'admin',
          'director',
          'secretaria',
          'Admin',
          'Director',
          'Secretaria',
          'ADMIN',
          'DIRECTOR',
          'SECRETARIA',
        ];
    }

    match /user/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    match /estudiantes/{studentId} {
      allow create: if isActiveStaff();
      allow read, update, delete: if isActiveStaff();
    }
  }
}
